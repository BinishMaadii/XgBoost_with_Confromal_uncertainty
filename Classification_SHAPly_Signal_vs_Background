RNG_SEED = 42
np.random.seed(RNG_SEED)



DR2_DATA_DIR = "icetracks_dr2/events"   # <- point this at your unzipped Dataverse download
DR2_DOI_URL = "https://doi.org/10.7910/DVN/MMIIZA"


def load_local_dr2(data_dir: str) -> pd.DataFrame:
    files = [f for f in os.listdir(data_dir) if f.lower().endswith((".csv", ".txt"))]
    if not files:
        raise FileNotFoundError(f"No event files found in {data_dir}")
    frames = []
    for fn in sorted(files):
        df = pd.read_csv(os.path.join(data_dir, fn), sep=None, engine="python")
        df.columns = [c.strip() for c in df.columns]
        frames.append(df)
    return pd.concat(frames, ignore_index=True)


def make_synthetic_icecube(n_events: int = 200_000, seed: int = RNG_SEED) -> pd.DataFrame:
    '''
    Schema-matched synthetic stand-in for IceTracks-DR2, used only if no local
    data release is found. Encodes two well-known real effects so the
    classification task isn't trivial-by-construction:
      - atmospheric background dominates the Northern sky (Earth shields
        atmospheric muons; neutrinos pass through) and falls off steeply
        with energy (~E^-3.7)
      - the harder astrophysical-like population is flatter in declination
        and has a harder spectrum (~E^-2.0 to -2.5)
    '''
    rng = np.random.default_rng(seed)
    dec = np.degrees(np.arcsin(rng.uniform(-1, 1, n_events)))  # isotropic on the sky
    ra = rng.uniform(0, 360, n_events)
    zenith = 90 - dec
    azimuth = rng.uniform(0, 360, n_events)

    def powerlaw_sample(n, gamma, e_min, e_max=1e8):
        u = rng.random(n)
        a, b = e_min ** (1 - gamma), e_max ** (1 - gamma)
        return (a + u * (b - a)) ** (1 / (1 - gamma))

    # true (hidden) latent population -- only used to build a realistic energy
    # spectrum; the classifier never sees this, it only sees the reweighted
    # pseudo-labels built downstream from log10(E/GeV) and declination
    frac_astro = 0.02
    is_astro_latent = rng.random(n_events) < frac_astro
    e_conv = powerlaw_sample(n_events, gamma=3.0, e_min=100)      # steep, soft
    e_astro = powerlaw_sample(n_events, gamma=2.2, e_min=800)     # hard, rare
    e_gev = np.where(is_astro_latent, e_astro, e_conv)

    # atmospheric component is suppressed in the Southern sky (higher energy
    # threshold from the down-going muon veto); astrophysical is isotropic
    dec_suppression = np.where(is_astro_latent, 1.0, np.clip(1.3 - dec / 250, 0.35, None))
    e_gev = e_gev * dec_suppression
    log10E = np.log10(np.clip(e_gev, 100, 1e8))

    ang_err = np.clip(rng.gamma(2.0, 0.35 / (1 + 0.15 * (log10E - 3))), 0.05, 5.0)
    mjd = rng.uniform(54000, 59900, n_events)

    return pd.DataFrame({
        "MJD[days]": mjd,
        "log10(E/GeV)": log10E,
        "AngErr[deg]": ang_err,
        "RA[deg]": ra,
        "Dec[deg]": dec,
        "Azimuth[deg]": azimuth,
        "Zenith[deg]": zenith,
    })


try:
    events = load_local_dr2(DR2_DATA_DIR)
    print(f"Loaded real IceTracks-DR2 data: {len(events)} events from {DR2_DATA_DIR}")
except Exception as exc:
    print(f"[info] No local IceTracks-DR2 files found ({exc}).")
    print(f"       Download the real release from: {DR2_DOI_URL}")
    print(f"       unzip it into '{DR2_DATA_DIR}', then re-run this cell.")
    print("       Using synthetic schema-matched data for now.")
    events = make_synthetic_icecube()

